{
  "manifest_version": 3,
  "name": "Nighter — Dark Mode Toggle",
  "version": "1.0.0",
  "description": "One-click dark mode for any website. Toggle a comfortable dark theme per-site, with brightness and contrast tuning.",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Nighter — Toggle dark mode",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles/darkmode.css"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "commands": {
    "toggle-dark-mode": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Toggle dark mode on the current site"
    }
  }
}
